<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/base"
    android:gravity="center_horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_media_previous"
            android:tint="@color/text_muted"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Voice Input"
            android:textColor="@color/text_main"
            android:textSize="17sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening..."
        android:textColor="@color/olive"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="180dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_voice_ring"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <View android:id="@+id/bar1"
                android:layout_width="5dp"
                android:layout_height="20dp"
                android:background="@color/olive"
                android:layout_marginStart="4dp"/>
            <View android:id="@+id/bar2"
                android:layout_width="5dp"
                android:layout_height="40dp"
                android:background="@color/olive"
                android:layout_marginStart="4dp"/>
            <View android:id="@+id/bar3"
                android:layout_width="5dp"
                android:layout_height="60dp"
                android:background="@color/olive"
                android:layout_marginStart="4dp"/>
            <View android:id="@+id/bar4"
                android:layout_width="5dp"
                android:layout_height="40dp"
                android:background="@color/olive"
                android:layout_marginStart="4dp"/>
            <View android:id="@+id/bar5"
                android:layout_width="5dp"
                android:layout_height="20dp"
                android:background="@color/olive"
                android:layout_marginStart="4dp"/>

        </LinearLayout>
    </FrameLayout>

    <EditText
        android:id="@+id/et_voice_text"
        android:layout_width="280dp"
        android:layout_height="44dp"
        android:hint="Your words appear here..."
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_dim"
        android:background="@drawable/bg_input"
        android:gravity="center"
        android:textSize="14sp"
        android:layout_marginTop="32dp"
        android:focusable="false"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap to stop"
        android:textColor="@color/text_dim"
        android:textSize="13sp"
        android:layout_marginTop="20dp"/>

    <ImageButton
        android:id="@+id/btn_stop"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_circle_surface"
        android:src="@android:drawable/ic_delete"
        android:tint="@color/text_muted"
        android:layout_marginTop="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>
