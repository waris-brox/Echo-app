<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        android:background="@color/surface">

        <ImageView
            android:id="@+id/header_logo"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/logo_small"
            android:scaleType="fitCenter"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Echo"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:letterSpacing="0.1"
            android:layout_marginStart="10dp"/>

        <ImageButton
            android:id="@+id/btn_settings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_manage"
            android:background="@drawable/circle_btn_bg"
            android:tint="@color/accent"
            android:contentDescription="Settings"/>

    </LinearLayout>

    <!-- Messages -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="20dp">

        <LinearLayout
            android:id="@+id/messages_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Greeting shown when no messages -->
            <LinearLayout
                android:id="@+id/greeting_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="60dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✦"
                    android:textSize="40sp"
                    android:textColor="@color/text_dim"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/greeting_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Boss"
                    android:textSize="26sp"
                    android:textColor="@color/text_muted"
                    android:fontFamily="sans-serif-light"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How can I assist you today?"
                    android:textSize="14sp"
                    android:textColor="@color/text_dim"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Typing indicator -->
    <LinearLayout
        android:id="@+id/typing_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="20dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="@color/accent"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Echo is thinking…"
            android:textSize="13sp"
            android:textColor="@color/text_muted"/>

    </LinearLayout>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/bg">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="18dp"
            android:layout_marginEnd="10dp">

            <EditText
                android:id="@+id/input_message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Ask here..."
                android:hintTextColor="@color/text_dim"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:paddingVertical="10dp"
                android:background="@null"
                android:maxLines="4"
                android:inputType="textMultiLine"
                android:imeOptions="actionSend"/>

            <ImageButton
                android:id="@+id/btn_voice"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_btn_speak_now"
                android:background="@null"
                android:tint="@color/accent"
                android:contentDescription="Voice input"/>

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_send"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/circle_btn_bg"
            android:tint="@color/accent"
            android:contentDescription="Send"/>

    </LinearLayout>

</LinearLayout>
